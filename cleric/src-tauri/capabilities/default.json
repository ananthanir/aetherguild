{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "shell:allow-kill",
    {
      "identifier": "shell:allow-spawn",
      "allow": [{ "name": "druid", "sidecar": true }]
    }
  ]
}
